{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"lib": ["ES2022", "DOM"],
		"types": ["bun-types"],
		"noEmit": true
	},
	"include": ["src/**/*"]
}
