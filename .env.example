# --- Phantom Connect (https://portal.phantom.com) ---------------------------
# Use the React SDK in-app; paste the same App ID here. In Portal add every
# origin under "Allowed Origins" and every callback under "Redirect URLs"
# — run the app once and read values from Bun logs / RPC `phantomGetPortalConfig`
# (`portalAllowedOrigins`, `portalRedirectUrls`) or inspect the handler in
# `src/bun/core/rpc/handlers/phantom.ts`.

PHANTOM_CONNECT_APP_ID=

# Optional: exact redirect URL (must also appear in Portal → Redirect URLs).
# If unset, derived from DETOUR_DEV_URL + portless (see phantom handler).
# PHANTOM_CONNECT_REDIRECT_URL=https://your-domain.example.com/

# Dev shell origin (Vite / tunnel). Non-loopback hosts skip portless and use
# this origin directly as redirect — good for ngrok / Cloudflare Tunnel.
# DETOUR_DEV_URL=http://127.0.0.1:5183

# Public DNS name that resolves to your machine (Portal TXT verification).
# Portless routes this host → DETOUR_DEV_URL port when the proxy is running.
# PHANTOM_PORTLESS_FQDN=phantom-auth.your-domain.example.com
