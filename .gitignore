# Local env (never commit). Keep `.env.example` tracked.
.env
.env.local

node_modules/
build/
dist/
dist-agent/
artifacts/
*.tsbuildinfo

# Generated icon + WASM/data assets — regenerated by `bun run prepare`.
# Source images (`source-tray.png`, `source-app-icon.png`) ARE tracked.
packages/tray/build-assets/tray/
packages/tray/build-assets/app-icon/
packages/tray/build-assets/pglite/
packages/tray/build-assets/llama/
packages/web/public/favicon-*.png
packages/web/public/favicon.ico
packages/web/public/apple-touch-icon.png

# Runtime lockfile written by core's API server.
.detour/
*/.detour/

# Random scratch files at repo root.
/*.png
/*.jpg
/*.jpeg

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Logs from local dev runs.
/tmp/detour-dev.log
*.log

# Eliza local data (vault, audit, auth) — NEVER commit.
.eliza/
.agents/
.xhawk/
.claude/settings.local.json
.codex/hooks.json
.codex/config.toml
.cursor/hooks.json
.opencode/plugins/xh-hooks.js
.claude/worktrees/

# Eliza DB exports (regenerated by export scripts; the two `components-*`
# dumps are ~226MB and exceed GitHub's 100MB limit). Run the export
# scripts locally if you need fresh data; do not commit the output.
eliza/*-export.json
eliza/*-export.jsonl
