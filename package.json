{
  "name": "detour",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "start": "electrobun dev",
    "dev": "electrobun dev --watch",
    "build:dev": "electrobun build --env=dev",
    "build:canary": "electrobun build --env=canary",
    "build:stable": "electrobun build --env=stable",
    "typecheck": "tsc --noEmit",
    "build:eliza": "bun run --cwd eliza/packages/shared build:i18n && bun run --cwd eliza/packages/core build && bun run --cwd eliza/packages/shared build:dist && bun run --cwd eliza/packages/vault build && bun run --cwd eliza/plugins/plugin-sql build && bun run --cwd eliza/plugins/plugin-anthropic build && bun run --cwd eliza/plugins/plugin-openai build && bun run --cwd eliza/plugins/plugin-imessage build && bun run --cwd eliza/plugins/plugin-discord build && (cd eliza/plugins/plugin-github && bunx tsup src/index.ts src/register-routes.ts --format esm --no-dts --clean) && (cd eliza/plugins/plugin-telegram && bunx tsup --no-dts)"
  },
  "dependencies": {
    "@electric-sql/pglite": "*",
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-agent-orchestrator": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-coding-tools": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-github": "workspace:*",
    "@elizaos/plugin-imessage": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "@elizaos/plugin-telegram": "workspace:*",
    "@elizaos/skills": "workspace:*",
    "@elizaos/vault": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@napi-rs/keyring": "^1.3.0",
    "drizzle-orm": "0.45.2",
    "electrobun": "1.18.1",
    "monaco-editor": "^0.55.1",
    "portless": "^0.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "bun-types": "^1.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "workspaces": [
    "eliza/packages/*",
    "eliza/packages/native-plugins/*",
    "eliza/packages/app-core/platforms/*",
    "eliza/packages/app-core/deploy/cloud-agent-template",
    "eliza/apps/*",
    "eliza/plugins/*",
    "eliza/cloud/packages/sdk"
  ]
}
