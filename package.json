{
  "name": "detour",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "start": "electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:web": "vite --host 127.0.0.1 --port 5180",
    "build:dev": "electrobun build --env=dev",
    "build:canary": "electrobun build --env=canary",
    "build:stable": "electrobun build --env=stable",
    "build:app": "bun run build:stable",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/bun src/main src/shared",
    "test:watch": "bun test --watch src/bun src/main src/shared",
    "check:flow": "depcruise src --config .dependency-cruiser.cjs --ignore-known",
    "check:flow:all": "depcruise src --config .dependency-cruiser.cjs",
    "check:cycles": "madge --circular --extensions ts,tsx src",
    "verify:agents": "bun run scripts/verify-codex-setup.ts",
    "build:eliza": "bun run --cwd eliza/packages/shared build:i18n && bun run --cwd eliza/packages/core build && bun run --cwd eliza/packages/shared build:dist && bun run --cwd eliza/packages/vault build && bun run --cwd eliza/packages/skills build && bun run --cwd eliza/plugins/plugin-sql build && bun run --cwd eliza/plugins/plugin-local-embedding build && bun run --cwd eliza/plugins/plugin-anthropic build && bun run --cwd eliza/plugins/plugin-openai build && bun run --cwd eliza/plugins/plugin-imessage build && bun run --cwd eliza/plugins/plugin-discord build && bun run --cwd eliza/plugins/plugin-coding-tools build && bun run --cwd eliza/plugins/plugin-agent-skills build && bun run --cwd eliza/plugins/plugin-agent-orchestrator build && (cd eliza/plugins/plugin-pdf && bun run build.ts) && (cd eliza/plugins/plugin-elizacloud && bun run build.ts) && (cd eliza/plugins/plugin-github && bunx tsup src/index.ts src/register-routes.ts --format esm --no-dts --clean) && bun run --cwd eliza/plugins/plugin-telegram build && bun run --cwd eliza/plugins/plugin-mcp build && (cd eliza/plugins/plugin-web-search && bunx tsup)"
  },
  "dependencies": {
    "@electric-sql/pglite": "*",
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-agent-orchestrator": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-coding-tools": "workspace:*",
    "@elizaos/plugin-discord": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-github": "workspace:*",
    "@elizaos/plugin-imessage": "workspace:*",
    "@elizaos/plugin-mcp": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "@elizaos/plugin-telegram": "workspace:*",
    "@elizaos/skills": "workspace:*",
    "@elizaos/vault": "workspace:*",
    "@elizaos-plugins/plugin-web-search": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@napi-rs/keyring": "^1.3.0",
    "@phantom/browser-sdk": "^2.0.2",
    "@phantom/react-sdk": "^2.0.2",
    "@solana/web3.js": "^1.98.4",
    "@x402/fetch": "^2.13.0",
    "agentmail": "^0.5.3",
    "drizzle-orm": "0.45.2",
    "electrobun": "1.18.1",
    "json5": "^2.2.3",
    "lucide-react": "^1.16.0",
    "monaco-editor": "^0.55.1",
    "portless": "^0.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.0.0",
    "viem": "^2.48.11",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "bun-types": "^1.3.0",
    "dependency-cruiser": "^17.4.2",
    "madge": "^8.0.0",
    "playwright": "1.50.1",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  },
  "workspaces": [
    "eliza/packages/*",
    "eliza/packages/native-plugins/*",
    "eliza/packages/app-core/platforms/*",
    "eliza/packages/app-core/deploy/cloud-agent-template",
    "eliza/apps/*",
    "eliza/plugins/*",
    "eliza/cloud/packages/sdk"
  ]
}
