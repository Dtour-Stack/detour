#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

bun run scripts/verify-codex-setup.ts --hook
bun run verify:swift

TESTS=$(find src -name "*.test.ts" -not -path "*/node_modules/*")
if [[ -z "$TESTS" ]]; then
	echo "pre-push found no src tests" >&2
	exit 1
fi

bun test $TESTS
bun run typecheck
